<UserControl x:Class="DumbTrader.Views.StockCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="270" d:DesignHeight="170">
    <Border Style="{StaticResource StockCard}">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Section: Info + Graph -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <!-- 종목명 -->
                    <TextBlock Text="{Binding hname}" d:Text="삼성전자" Foreground="{StaticResource Brush.TextPrimary}" FontWeight="Bold" FontSize="18"/>
                    <!-- 현재가 -->
                    <TextBlock Text="{Binding price}" d:Text="1,200,000" Foreground="{StaticResource Brush.TextPrimary}" FontSize="16" Margin="0,4,0,0"/>
                    <!-- Change & Rate -->
                    <StackPanel Orientation="Vertical" Margin="0,4,0,0">
                        <!-- 전일대비 -->
                        <TextBlock Text="{Binding change}" d:Text="▲20,000" FontSize="14"/>
                        <!-- 등락율 -->
                        <TextBlock Text="{Binding drate, StringFormat={}{0:F2}%}" d:Text="+2.3%" FontSize="14" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 그래프 -->
                <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="5">
                    <Viewbox Stretch="Fill">
                        <Path StrokeThickness="1" d:Data="M0,40 L20,30 L40,34 L60,22 L80,18 L100,8"/>
                    </Viewbox>
                </Border>
            </Grid>

            <!-- Bottom Section: Detailed Info -->
            <Grid Grid.Row="1" Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Bid/Ask (Left) -->
                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Left">
                    <TextBlock Text="호가" HorizontalAlignment="Center" FontSize="10" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="매수: " FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <!-- 매수호가 -->
                        <TextBlock Text="{Binding bidho}" d:Text="1,200,000" FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="매도: " FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <!-- 매도호가 -->
                        <TextBlock Text="{Binding offerho}" d:Text="1,200,000" FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Open/High/Low (Right) -->
                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="시가: " FontSize="10" Foreground="{StaticResource Brush.TextPrimary}" />
                        <!-- 시가 -->
                        <TextBlock Text="{Binding open}" d:Text="1,200,000" FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="고가: " FontSize="10" Foreground="{StaticResource Brush.TextPrimary}" />
                        <!-- 고가 -->
                        <TextBlock Text="{Binding high}" d:Text="1,210,000" FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="저가: " FontSize="10" Foreground="{StaticResource Brush.TextPrimary}" />
                        <!-- 저가 -->
                        <TextBlock Text="{Binding low}" d:Text="1,110,000" FontSize="10" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- 전략 상태 정보 표시 -->
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="4,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="전략: " FontSize="12" Foreground="{StaticResource Brush.TextPrimary}" />
                        <TextBlock Text="매수추종" FontSize="12" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="목표가: " FontSize="12" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Text="1,210,000" FontSize="12" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="수익률: " FontSize="12" Foreground="{StaticResource Brush.TextPrimary}"/>
                        <TextBlock Text="+200,000" FontSize="12" Foreground="{StaticResource Brush.TextPrimary}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
