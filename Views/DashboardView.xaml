<UserControl x:Class="DumbTrader.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:DumbTrader.Views"
             mc:Ignorable="d"> 
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16" Background="{StaticResource Brush.Background}">
        <StackPanel>
            <TextBlock Style="{StaticResource Heading}" Text="STOCKS" />
            <UniformGrid Columns="4" Rows="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,4,0,0">
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="AAPL"
                                           ChangeText="+2.3%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,40 L20,30 L40,34 L60,22 L80,18 L100,8"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="MSFT"
                                           ChangeText="+1.8%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,40 L20,36 L40,28 L60,22 L80,14 L100,10"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="AMZN"
                                           ChangeText="+3.2%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,38 L25,28 L50,32 L75,18 L100,12"/>
                <controls:StockCardControl Margin="0,0,0,16"
                                           Symbol="AOGN"
                                           ChangeText="+0.7%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,42 L20,34 L40,36 L60,26 L80,18 L100,16"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="TSLA"
                                           ChangeText="-1.2%"
                                           ChangeStyle="{StaticResource ValueRed}"
                                           SparklineStyle="{StaticResource SparklineDown}"
                                           SparklineData="M0,10 L20,16 L40,18 L60,28 L80,34 L100,38"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="META"
                                           ChangeText="+2.7%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,36 L20,30 L40,26 L60,20 L80,16 L100,12"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="NVDA"
                                           ChangeText="+4.5%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,40 L20,38 L40,30 L60,22 L80,16 L100,14"/>
                <controls:StockCardControl Margin="0,0,0,16"
                                           Symbol="GOOG"
                                           ChangeText="-0.3%"
                                           ChangeStyle="{StaticResource ValueRed}"
                                           SparklineStyle="{StaticResource SparklineDown}"
                                           SparklineData="M0,16 L20,20 L40,28 L60,32 L80,36 L100,34"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="BRKB"
                                           ChangeText="+1.1%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,42 L25,34 L50,36 L75,26 L100,20"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="VI"
                                           ChangeText="+0.9%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,44 L20,38 L40,36 L60,30 L80,26 L100,22"/>
                <controls:StockCardControl Margin="0,0,16,16"
                                           Symbol="V"
                                           ChangeText="+0.9%"
                                           ChangeStyle="{StaticResource ValueGreen}"
                                           SparklineStyle="{StaticResource SparklineUp}"
                                           SparklineData="M0,40 L25,36 L50,32 L75,26 L100,20"/>
                <controls:StockCardControl Margin="0,0,0,16"
                                           Symbol="JNJ"
                                           ChangeText="-2.0%"
                                           ChangeStyle="{StaticResource ValueRed}"
                                           SparklineStyle="{StaticResource SparklineDown}"
                                           SparklineData="M0,10 L25,14 L50,22 L75,30 L100,36"/>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
